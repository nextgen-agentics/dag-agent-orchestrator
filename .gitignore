# Secrets — NEVER commit
.env
.env.local

# Local runtime state — regenerated on each run
agent/state/*
!agent/state/.gitkeep
agent/sandbox/*
!agent/sandbox/.gitkeep
agent/.venv/
gateway/.venv/
gateway/*.db
gateway/usage.json

# Build / cache artifacts
**/__pycache__/
**/*.pyc
**/uv.lock
**/.pytest_cache/

# Editors
.vscode/
.idea/
.DS_Store

usage.json